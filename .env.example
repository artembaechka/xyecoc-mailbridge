REMOTE_HTTP_BASE=https://api.xyecoc.com

# GET /mail/... и вложения; пусто = для api.xyecoc.com подставится cdn.xyecoc.com (см. internal/config)
REMOTE_ASSET_BASE=https://cdn.xyecoc.com

# К логину без «@» дописать домен (например xyecoc.com). off или - = не дописывать
# MAIL_DEFAULT_DOMAIN=

# В account/authorization в data.email только локальная часть (user), без @домен
REMOTE_AUTH_EMAIL_LOCAL_PART_ONLY=true

# --- Языки / currentLang для разных действий API ---
MAILBRIDGE_LANG=ru
MAILBRIDGE_MAIL_CURRENT_LANG=inbox
MAILBRIDGE_MAIL_VIEW_LANG=mail
MAILBRIDGE_MAIL_COMPOSE_LANG=mail

# Hex без # для mail/tag-new при IMAP CREATE tag/Имя или Labels/Имя
# MAILBRIDGE_TAG_DEFAULT_COLOR=ADACF1

# --- Слушатели (в Docker обычно :143 и :587 внутри контейнера) ---
IMAP_ADDR=:143
SMTP_ADDR=:587

# true: LOGIN/PLAIN без TLS на сокете (нормально за reverse proxy с TLS на edge)
IMAP_ALLOW_INSECURE_AUTH=true

# --- HTTP-клиент к API ---
HTTP_TIMEOUT_SEC=60
MAX_MAIL_LIST=5000

# --- Логи (stdout, JSON) ---
LOG_LEVEL=info
# 1 = логировать тела POST /request (секреты маскируются). По умолчанию включается при LOG_LEVEL=debug
# REMOTE_HTTP_TRACE=1
# 1 = построчный лог команд/ответов IMAP и SMTP
# MAILBRIDGE_PROTOCOL_LOG=1